{
  "rules": {
    // TRANSITIONAL (Phase 1 launch-in-progress): reads stay OPEN so no kid on
    // the legacy room loses access during the multi-family migration, but every
    // WRITE is locked down. Read-isolation (per-family) is the next tightening,
    // once families are migrated and the flow is verified.
    ".read": true,
    ".write": false,

    // A grown-up manages only their own reverse-lookup of families.
    "users": {
      "$uid": {
        ".write": "auth != null && auth.uid === $uid"
      }
    },

    // Family data: writable by members; OR a signed-in user may CREATE a new
    // family as long as the same write installs them as a parent member
    // (the bootstrap clause — no backend needed).
    "families": {
      "$familyId": {
        ".write": "auth != null && (data.child('members').child(auth.uid).exists() || (!data.exists() && newData.child('members').child(auth.uid).child('role').val() === 'parent'))",
        "submissions": {
          "$sid": {
            "photo": {
              ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 300000)"
            }
          }
        },
        "messages": {
          "$mid": {
            "text": {
              ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 4000)"
            },
            "photo": {
              ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 300000)"
            }
          }
        }
      }
    },

    // Legacy single-family room: writable by any signed-in client (anonymous
    // kids' devices included) during the migration window.
    "rooms": {
      "$roomCode": {
        ".write": "auth != null"
      }
    },

    // Cloud-Function-managed only (Phase 2).
    "invites": { ".write": false },
    "deviceGrants": { ".write": false }
  }
}
